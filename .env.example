# ============================================
# PostgreSQL Configuration
# ============================================
# Option A (recommended for managed Postgres like Neon/Supabase/Aiven):
# paste the full connection string. It is used verbatim, so keep its
# ?sslmode=require suffix. Leave the discrete DB_* vars blank if you use this.
DATABASE_URL=

# Option B: discrete parameters (typical for local Docker). DB_PASSWORD has
# NO default in code — it must be set here, never committed.
POSTGRES_DB=crypto_etl
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_me
DB_PORT=5432
# prefer (local) | require (managed cloud Postgres over the public internet)
DB_SSLMODE=prefer

# ============================================
# Pipeline Configuration
# ============================================
COINS=bitcoin,ethereum,solana
VS_CURRENCY=usd
HISTORY_DAYS=30
MAX_RETRIES=3
RETRY_DELAY=5

# Optional CoinGecko Demo API key — higher, more reliable free rate limits.
# Get one at https://www.coingecko.com/en/developers/dashboard
COINGECKO_API_KEY=
